{
    "name": "pescheck/example-php",
    "description": "Minimal end-to-end example: list Pescheck check types using the generated PHP client.",
    "type": "project",
    "license": "unlicense",
    "repositories": [
        {
            "type": "path",
            "url": "../../clients/php"
        }
    ],
    "require": {
        "php": "^8.1",
        "pescheckit/pescheck-clients": "*@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Pescheck\\Example\\Tests\\": "tests/"
        }
    }
}
