{
    "name": "pescheckit/pescheck-clients",
    "description": "Official Pescheck API PHP SDK (generated). Install via `composer require pescheckit/pescheck-clients`.",
    "type": "library",
    "license": "unlicense",
    "homepage": "https://pescheck.io",
    "support": {
        "source": "https://github.com/pescheckit/pescheck-clients",
        "issues": "https://github.com/pescheckit/pescheck-clients/issues"
    },
    "keywords": ["pescheck", "api", "sdk", "rest", "php", "official"],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "autoload": {
        "psr-4": { "Pescheck\\Client\\": "clients/php/lib/" }
    }
}
